# =============================================================================
# Signage Portal — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your client deployment.

# Site URL (used by PDF generators for asset URLs)
SITE_URL=https://your-client-signage.vercel.app

# Lead capture (client-side — uses anon key)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
