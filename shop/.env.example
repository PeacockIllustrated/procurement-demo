# =============================================================================
# Signage Portal — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your client deployment.
# See REBRAND.md for the full setup guide.

# Supabase (shared instance — same for all clients)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth passwords (set unique values per client)
SHOP_PASSWORD=change-me
ADMIN_PASSWORD=change-me

# Auth tokens — generate with: openssl rand -hex 32
SHOP_AUTH_TOKEN=generate-a-new-token
ADMIN_AUTH_TOKEN=generate-a-new-token

# Site URL (for email images and links)
SITE_URL=https://your-client-signage.vercel.app

# Make.com webhook for order routing (optional)
MAKE_WEBHOOK_URL=

# Email (Office365 SMTP)
SMTP_USER=
SMTP_PASS=

# Team notification email (receives order alerts)
TEAM_NOTIFICATION_EMAIL=

# Nest system email for PO requests (optional)
NEST_EMAIL=

# Raise PO token secret — generate with: openssl rand -hex 16
RAISE_PO_SECRET=

# Lead capture (client-side — uses anon key, NOT service role key)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
